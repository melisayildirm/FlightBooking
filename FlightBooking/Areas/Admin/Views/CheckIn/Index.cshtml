
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Layout/AdminLayout.cshtml";
}
@* ============================================================
   Areas/Admin/Views/Bookings/CheckIn.cshtml
   SADECE CONTENT — Layout hazır
   ViewBag: FlightNumber, AirlineCode,
            DepartureAirportCode, DepartureAirportName,
            ArrivalAirportCode,   ArrivalAirportName,
            DepartureTime, ArrivalTime,
            PassengerName, Pnr, Gate,
            BasePrice, Currency
============================================================ *@

@{
    Layout = "~/Areas/Admin/Views/Layout/AdminLayout.cshtml";
    ViewData["Title"] = "Check-In";
}

@section Styles {
    <style>

        .ci-page {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* ── Flight Banner ────────────────────────────────────── */
        .ci-banner {
            background: #0B1B3A;
            border-radius: 14px;
            padding: 22px 28px;
            position: relative;
            overflow: hidden;
        }

            .ci-banner::before {
                content: '';
                position: absolute;
                inset: 0;
                background: repeating-linear-gradient(-45deg,rgba(255,255,255,.018) 0,rgba(255,255,255,.018) 1px,transparent 1px,transparent 9px);
                pointer-events: none;
            }

        .ci-banner-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
        }

        .ci-route {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .ci-apt-code {
            font-family: 'Syne',sans-serif;
            font-size: 32px;
            font-weight: 800;
            color: #fff;
            letter-spacing: -.4px;
            line-height: 1;
        }

        .ci-apt-name {
            font-size: 10.5px;
            color: rgba(255,255,255,.3);
            margin-top: 2px;
            text-align: center;
        }

        .ci-route-mid {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            flex-shrink: 0;
        }

        .ci-route-line {
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .ci-route-line::before, .ci-route-line::after {
                content: '';
                display: block;
                height: 1px;
                width: 28px;
                background: rgba(255,255,255,.2);
            }

            .ci-route-line i {
                font-size: 15px;
                color: #3B8EF5;
            }

        .ci-route-dur {
            font-size: 10px;
            color: rgba(255,255,255,.3);
            font-weight: 600;
            letter-spacing: .4px;
        }

        .ci-bp-divider {
            border: none;
            border-top: 2px dashed rgba(255,255,255,.1);
            margin: 16px 0;
        }

        .ci-banner-meta {
            display: grid;
            grid-template-columns: repeat(6,auto);
            gap: 16px 32px;
        }

        .ci-meta-item {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .ci-meta-key {
            font-size: 9.5px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: rgba(255,255,255,.3);
        }

        .ci-meta-val {
            font-size: 13.5px;
            font-weight: 600;
            color: rgba(255,255,255,.85);
        }

        .ci-status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 5px 13px;
            border-radius: 99px;
            font-size: 12px;
            font-weight: 700;
            background: rgba(16,185,129,.2);
            color: #6EE7B7;
            border: 1px solid rgba(16,185,129,.25);
        }

            .ci-status-badge .dot {
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: #10B981;
                flex-shrink: 0;
                animation: ci-blink 1.4s ease-in-out infinite;
            }

        @@keyframes ci-blink {
            0%, 100% {
                opacity: 1
            }

            50% {
                opacity: .2
            }
        }

        /* ── Layout ───────────────────────────────────────────── */
        .ci-layout {
            display: grid;
            grid-template-columns: 1fr 290px;
            gap: 20px;
            align-items: start;
        }

        .ci-col-main {
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .ci-col-side {
            display: flex;
            flex-direction: column;
            gap: 14px;
            position: sticky;
            top: 80px;
        }

        /* ── Tab Stepper ──────────────────────────────────────── */
        .tab-stepper {
            display: flex;
            align-items: stretch;
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 14px 14px 0 0;
            border-bottom: none;
            overflow: hidden;
        }

        .tab-step {
            flex: 1;
            padding: 16px 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            border-right: 1px solid #f1f5f9;
            border-bottom: 3px solid transparent;
            transition: all .18s;
            position: relative;
            background: #f8fafc;
            user-select: none;
        }

            .tab-step:last-child {
                border-right: none;
            }

            .tab-step.active {
                background: #fff;
                border-bottom-color: #2563eb;
            }

            .tab-step.done {
                background: #f0fdf4;
                border-bottom-color: #10B981;
            }

        .tab-step-num {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 800;
            flex-shrink: 0;
            background: #e2e8f0;
            color: #64748b;
            transition: all .18s;
        }

        .tab-step.active .tab-step-num {
            background: #2563eb;
            color: #fff;
        }

        .tab-step.done .tab-step-num {
            background: #10B981;
            color: #fff;
        }

        .tab-step-text {
            display: flex;
            flex-direction: column;
            gap: 1px;
        }

        .tab-step-title {
            font-size: 12.5px;
            font-weight: 700;
            color: #0f172a;
            white-space: nowrap;
        }

        .tab-step-desc {
            font-size: 10.5px;
            color: #94a3b8;
            white-space: nowrap;
        }

        .tab-step.active .tab-step-title {
            color: #2563eb;
        }

        .tab-step.done .tab-step-title {
            color: #16a34a;
        }

        /* ── Tab Panels ───────────────────────────────────────── */
        .tab-panels {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 0 0 14px 14px;
            box-shadow: 0 1px 4px rgba(15,23,42,.06);
        }

        .tab-panel {
            display: none;
            padding: 24px;
        }

            .tab-panel.active {
                display: block;
                animation: ci-fade-in .2s ease;
            }

        @@keyframes ci-fade-in {
            from {
                opacity: 0;
                transform: translateY(6px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        .tab-panel-title {
            font-family: 'Syne',sans-serif;
            font-size: 15px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 4px;
        }

        .tab-panel-desc {
            font-size: 12.5px;
            color: #94a3b8;
            margin-bottom: 20px;
        }

        /* ── Tab Navigation Buttons ───────────────────────────── */
        .tab-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 24px;
            padding-top: 20px;
            border-top: 1px solid #f1f5f9;
        }

        .btn-tab-nav {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 9px 20px;
            border-radius: 8px;
            font-family: 'DM Sans',sans-serif;
            font-size: 13.5px;
            font-weight: 600;
            cursor: pointer;
            transition: all .15s;
        }

        .btn-tab-prev {
            background: #f8fafc;
            color: #64748b;
            border: 1.5px solid #e2e8f0;
        }

            .btn-tab-prev:hover {
                border-color: #94a3b8;
                color: #0f172a;
            }

        .btn-tab-next {
            background: #2563eb;
            color: #fff;
            border: none;
        }

            .btn-tab-next:hover {
                background: #1d4ed8;
                box-shadow: 0 4px 14px rgba(37,99,235,.35);
            }

            .btn-tab-next:disabled {
                background: #e2e8f0;
                color: #94a3b8;
                cursor: not-allowed;
                box-shadow: none;
            }

        /* ── Bagaj ────────────────────────────────────────────── */
        .baggage-section {
            margin-bottom: 28px;
        }

            .baggage-section:last-child {
                margin-bottom: 0;
            }

        .baggage-section-title {
            font-size: 13.5px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .baggage-cards {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(200px,1fr));
            gap: 12px;
        }

        .baggage-card {
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            padding: 16px;
            background: #fff;
            cursor: pointer;
            transition: all .15s;
            position: relative;
            user-select: none;
        }

            .baggage-card:hover {
                border-color: #93c5fd;
                box-shadow: 0 3px 10px rgba(59,130,246,.1);
            }

            .baggage-card.selected {
                border-color: #2563eb;
                background: #eff6ff;
            }

            .baggage-card input {
                position: absolute;
                opacity: 0;
                pointer-events: none;
            }

        .bc-check {
            position: absolute;
            top: 10px;
            right: 10px;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            border: 1.5px solid #e2e8f0;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            color: transparent;
            transition: all .15s;
        }

        .baggage-card.selected .bc-check {
            background: #2563eb;
            border-color: #2563eb;
            color: #fff;
        }

        .bc-icon {
            font-size: 22px;
            margin-bottom: 8px;
        }

        .bc-name {
            font-size: 13px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 2px;
        }

        .bc-sub {
            font-size: 11.5px;
            color: #64748b;
            margin-bottom: 10px;
        }

        .bc-price {
            font-family: 'Syne',sans-serif;
            font-size: 14px;
            font-weight: 700;
            color: #2563eb;
        }

        /* Kg Slider */
        .kg-slider-wrap {
            margin-top: 16px;
            padding: 16px;
            background: #f8fafc;
            border-radius: 10px;
            border: 1px solid #f1f5f9;
        }

        .kg-slider-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .kg-slider-label {
            font-size: 12.5px;
            font-weight: 600;
            color: #475569;
        }

        .kg-display {
            font-family: 'Syne',sans-serif;
            font-size: 16px;
            font-weight: 800;
            color: #2563eb;
            background: #eff6ff;
            padding: 2px 12px;
            border-radius: 6px;
            min-width: 60px;
            text-align: center;
        }

        .kg-slider {
            -webkit-appearance: none;
            appearance: none;
            width: 100%;
            height: 6px;
            border-radius: 99px;
            background: linear-gradient(to right,#2563eb 0%,#2563eb var(--val,50%),#e2e8f0 var(--val,50%));
            outline: none;
            cursor: pointer;
            transition: background .15s;
        }

            .kg-slider::-webkit-slider-thumb {
                -webkit-appearance: none;
                appearance: none;
                width: 20px;
                height: 20px;
                border-radius: 50%;
                background: #2563eb;
                cursor: pointer;
                box-shadow: 0 2px 8px rgba(37,99,235,.4);
                border: 2px solid #fff;
            }

            .kg-slider::-moz-range-thumb {
                width: 20px;
                height: 20px;
                border-radius: 50%;
                background: #2563eb;
                cursor: pointer;
                box-shadow: 0 2px 8px rgba(37,99,235,.4);
                border: 2px solid #fff;
            }

        .kg-ticks {
            display: flex;
            justify-content: space-between;
            margin-top: 6px;
        }

        .kg-tick {
            font-size: 10px;
            color: #94a3b8;
            font-weight: 600;
        }

        /* ── Koltuk ───────────────────────────────────────────── */
        .smap-wrap {
            overflow-x: auto;
            padding-bottom: 6px;
        }

        .smap {
            display: flex;
            flex-direction: column;
            gap: 0;
            min-width: 300px;
        }

        .smap-hdr {
            display: grid;
            grid-template-columns: 26px repeat(3,31px) 22px repeat(3,31px);
            gap: 4px;
            justify-content: center;
            margin-bottom: 6px;
        }

        .smap-col-lbl {
            text-align: center;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: .7px;
            color: #94a3b8;
            text-transform: uppercase;
        }

        .smap-row {
            display: grid;
            grid-template-columns: 26px repeat(3,31px) 22px repeat(3,31px);
            gap: 4px;
            justify-content: center;
            margin-bottom: 4px;
        }

        .smap-row-num {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            font-size: 10px;
            font-weight: 600;
            color: #94a3b8;
            padding-right: 3px;
        }

        .seat {
            width: 31px;
            height: 31px;
            border-radius: 5px 5px 3px 3px;
            border: 1.5px solid #e2e8f0;
            background: #fff;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            font-weight: 700;
            color: #94a3b8;
            transition: all .13s;
            position: relative;
            user-select: none;
        }

            .seat::before {
                content: '';
                position: absolute;
                top: -5px;
                left: 50%;
                transform: translateX(-50%);
                width: 17px;
                height: 5px;
                background: #f1f5f9;
                border-radius: 3px 3px 0 0;
                border: 1.5px solid #e2e8f0;
                border-bottom: none;
                transition: background .13s,border-color .13s;
            }

            .seat:hover:not(.occupied):not(.selected) {
                border-color: #3b82f6;
                background: #eff6ff;
                color: #2563eb;
                transform: translateY(-1px);
                box-shadow: 0 3px 8px rgba(59,130,246,.18);
            }

                .seat:hover:not(.occupied):not(.selected)::before {
                    background: #eff6ff;
                    border-color: #3b82f6;
                }

            .seat.selected {
                background: #2563eb;
                border-color: #2563eb;
                color: #fff;
                box-shadow: 0 3px 10px rgba(37,99,235,.35);
                transform: translateY(-1px);
            }

                .seat.selected::before {
                    background: #3b82f6;
                    border-color: #3b82f6;
                }

            .seat.occupied {
                background: #f8fafc;
                border-color: #f1f5f9;
                color: #e2e8f0;
                cursor: not-allowed;
            }

                .seat.occupied::before {
                    background: #f1f5f9;
                    border-color: #f1f5f9;
                }

            .seat.window {
            }

                .seat.window::after {
                    content: '';
                    position: absolute;
                    right: -1px;
                    top: 50%;
                    transform: translateY(-50%);
                    width: 3px;
                    height: 14px;
                    background: rgba(59,130,246,.15);
                    border-radius: 2px;
                }

        .seat-legend {
            display: flex;
            align-items: center;
            gap: 16px;
            flex-wrap: wrap;
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid #f1f5f9;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: #94a3b8;
        }

        .legend-dot {
            width: 13px;
            height: 13px;
            border-radius: 3px;
            border: 1.5px solid #e2e8f0;
            background: #fff;
            flex-shrink: 0;
        }

            .legend-dot.ld-sel {
                background: #2563eb;
                border-color: #2563eb;
            }

            .legend-dot.ld-occ {
                background: #f8fafc;
                border-color: #f1f5f9;
            }

        .sel-seat-tag {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 5px 13px;
            border-radius: 99px;
            border: 1.5px solid #bfdbfe;
            background: #eff6ff;
            font-size: 12.5px;
            font-weight: 600;
            color: #2563eb;
            transition: all .15s;
        }

            .sel-seat-tag.empty {
                background: #f8fafc;
                border-color: #e2e8f0;
                color: #94a3b8;
            }

        /* Seat filters */
        .seat-filters {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 16px;
        }

        .seat-filter-btn {
            padding: 5px 13px;
            border-radius: 99px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            border: 1.5px solid #e2e8f0;
            background: #f8fafc;
            color: #64748b;
            transition: all .15s;
        }

            .seat-filter-btn.active {
                background: #eff6ff;
                border-color: #bfdbfe;
                color: #2563eb;
            }

        /* ── Yemek ────────────────────────────────────────────── */
        .meal-categories {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .meal-cat-btn {
            padding: 6px 14px;
            border-radius: 99px;
            font-size: 12.5px;
            font-weight: 600;
            cursor: pointer;
            border: 1.5px solid #e2e8f0;
            background: #f8fafc;
            color: #64748b;
            transition: all .15s;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .meal-cat-btn.active {
                background: #eff6ff;
                border-color: #bfdbfe;
                color: #2563eb;
            }

        .meal-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(210px,1fr));
            gap: 12px;
        }

        .meal-card {
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            cursor: pointer;
            transition: all .15s;
            position: relative;
        }

            .meal-card:hover {
                border-color: #93c5fd;
                box-shadow: 0 3px 10px rgba(59,130,246,.1);
                transform: translateY(-1px);
            }

            .meal-card.selected {
                border-color: #2563eb;
            }

        .meal-img {
            height: 90px;
            background: #f8fafc;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            border-bottom: 1px solid #f1f5f9;
            transition: background .15s;
        }

        .meal-card.selected .meal-img {
            background: #eff6ff;
        }

        .meal-check {
            position: absolute;
            top: 8px;
            right: 8px;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #fff;
            border: 1.5px solid #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            color: transparent;
            transition: all .15s;
            box-shadow: 0 1px 4px rgba(0,0,0,.1);
        }

        .meal-card.selected .meal-check {
            background: #2563eb;
            border-color: #2563eb;
            color: #fff;
        }

        .meal-info {
            padding: 12px;
        }

        .meal-name {
            font-size: 13px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 2px;
        }

        .meal-desc {
            font-size: 11px;
            color: #94a3b8;
            margin-bottom: 6px;
            line-height: 1.5;
        }

        .meal-tags {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
            margin-bottom: 8px;
        }

        .meal-tag {
            font-size: 10px;
            font-weight: 600;
            padding: 2px 7px;
            border-radius: 4px;
            background: #f1f5f9;
            color: #64748b;
        }

            .meal-tag.veg {
                background: #f0fdf4;
                color: #16a34a;
            }

            .meal-tag.hal {
                background: #fefce8;
                color: #a16207;
            }

            .meal-tag.hot {
                background: #fef2f2;
                color: #dc2626;
            }

            .meal-tag.cold {
                background: #eff6ff;
                color: #2563eb;
            }

        .meal-price {
            font-family: 'Syne',sans-serif;
            font-size: 13.5px;
            font-weight: 700;
            color: #2563eb;
        }

        .meal-free {
            font-family: 'Syne',sans-serif;
            font-size: 13.5px;
            font-weight: 700;
            color: #16a34a;
        }

        /* ── Ekstra Hizmetler ─────────────────────────────────── */
        .extras-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(200px,1fr));
            gap: 12px;
        }

        .extra-card {
            padding: 15px;
            border-radius: 10px;
            border: 1.5px solid #e2e8f0;
            background: #fff;
            cursor: pointer;
            transition: all .15s;
            position: relative;
            user-select: none;
        }

            .extra-card:hover {
                border-color: #93c5fd;
                box-shadow: 0 3px 10px rgba(59,130,246,.1);
            }

            .extra-card.selected {
                border-color: #2563eb;
                background: #eff6ff;
            }

            .extra-card input {
                position: absolute;
                opacity: 0;
                pointer-events: none;
            }

        .ec-check {
            position: absolute;
            top: 10px;
            right: 10px;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            border: 1.5px solid #e2e8f0;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            color: transparent;
            transition: all .15s;
        }

        .extra-card.selected .ec-check {
            background: #2563eb;
            border-color: #2563eb;
            color: #fff;
        }

        .ec-ico {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            margin-bottom: 9px;
        }

        .ec-name {
            font-size: 13px;
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 2px;
        }

        .ec-desc {
            font-size: 11px;
            color: #94a3b8;
            margin-bottom: 7px;
        }

        .ec-price {
            font-family: 'Syne',sans-serif;
            font-size: 13.5px;
            font-weight: 700;
            color: #2563eb;
        }

        /* ── Özet & Onay ──────────────────────────────────────── */
        .summary-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .summary-block {
            background: #f8fafc;
            border: 1px solid #f1f5f9;
            border-radius: 10px;
            padding: 16px;
        }

        .sb-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .6px;
            color: #94a3b8;
            margin-bottom: 10px;
        }

        .sb-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
            margin-bottom: 6px;
        }

            .sb-row:last-child {
                margin-bottom: 0;
            }

        .sb-lbl {
            color: #64748b;
        }

        .sb-val {
            font-weight: 600;
            color: #0f172a;
        }

        .sb-empty {
            font-size: 12px;
            color: #94a3b8;
            font-style: italic;
        }

        /* ── Price Summary (side) ─────────────────────────────── */
        .pr-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            font-size: 13px;
        }

            .pr-row + .pr-row {
                border-top: 1px solid #f1f5f9;
            }

        .pr-lbl {
            color: #94a3b8;
        }

        .pr-val {
            font-weight: 600;
            color: #0f172a;
        }

        .pr-total {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0 0;
            border-top: 2px solid #f1f5f9;
            margin-top: 4px;
        }

        .pr-total-lbl {
            font-family: 'Syne',sans-serif;
            font-weight: 700;
            font-size: 14px;
            color: #0f172a;
        }

        .pr-total-val {
            font-family: 'Syne',sans-serif;
            font-weight: 800;
            font-size: 20px;
            color: #2563eb;
        }

        /* ── Side Card ────────────────────────────────────────── */
        .ci-side-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 14px;
            box-shadow: 0 1px 4px rgba(15,23,42,.06);
            overflow: hidden;
        }

        .ci-side-card-head {
            padding: 14px 18px;
            border-bottom: 1px solid #f1f5f9;
            background: #f8fafc;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .ci-side-ico {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }

        .ci-side-title {
            font-family: 'Syne',sans-serif;
            font-size: 13px;
            font-weight: 700;
            color: #0f172a;
        }

        .ci-side-desc {
            font-size: 11px;
            color: #94a3b8;
            margin-top: 1px;
        }

        .ci-side-body {
            padding: 16px 18px;
        }

        /* ── Buttons ──────────────────────────────────────────── */
        .btn-ci {
            width: 100%;
            padding: 11px;
            border: none;
            border-radius: 9px;
            font-family: 'DM Sans',sans-serif;
            font-size: 13.5px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all .15s;
        }

        .btn-ci-primary {
            background: #2563eb;
            color: #fff;
        }

            .btn-ci-primary:hover {
                background: #1d4ed8;
                box-shadow: 0 4px 14px rgba(37,99,235,.35);
            }

        .btn-ci-secondary {
            background: #fff;
            color: #64748b;
            border: 1.5px solid #e2e8f0;
        }

            .btn-ci-secondary:hover {
                border-color: #94a3b8;
                color: #0f172a;
            }

        .btn-ci-success {
            background: #16a34a;
            color: #fff;
        }

            .btn-ci-success:hover {
                background: #15803d;
                box-shadow: 0 4px 14px rgba(22,163,74,.35);
            }

        /* ── Info Note ────────────────────────────────────────── */
        .ci-info-note {
            background: #eff6ff;
            border: 1px solid rgba(37,99,235,.15);
            border-radius: 8px;
            padding: 9px 12px;
            font-size: 11.5px;
            color: #2563eb;
            display: flex;
            gap: 7px;
            align-items: flex-start;
        }

        .ci-warn-note {
            background: #fffbeb;
            border: 1px solid #fde68a;
            border-radius: 8px;
            padding: 9px 12px;
            font-size: 11.5px;
            color: #d97706;
            display: flex;
            gap: 7px;
            align-items: flex-start;
        }

        /* ── Modal ────────────────────────────────────────────── */
        .ci-modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(11,27,58,.5);
            backdrop-filter: blur(5px);
            z-index: 9000;
            display: none;
            align-items: center;
            justify-content: center;
        }

            .ci-modal-overlay.open {
                display: flex;
                animation: ci-fade .2s ease;
            }

        @@keyframes ci-fade {
            from {
                opacity: 0
            }

            to {
                opacity: 1
            }
        }

        .ci-modal-box {
            background: #fff;
            border-radius: 16px;
            width: min(500px,calc(100vw - 40px));
            box-shadow: 0 8px 36px rgba(11,27,58,.18);
            padding: 30px 28px;
            text-align: center;
            animation: ci-scale .2s ease;
        }

        @@keyframes ci-scale {
            from {
                transform: scale(.94);
                opacity: 0
            }

            to {
                transform: scale(1);
                opacity: 1
            }
        }

        .ci-modal-ico {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: #f0fdf4;
            color: #16a34a;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 14px;
            font-size: 28px;
        }

        .ci-modal-title {
            font-family: 'Syne',sans-serif;
            font-size: 18px;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 6px;
        }

        .ci-modal-desc {
            font-size: 13px;
            color: #94a3b8;
            line-height: 1.7;
            margin-bottom: 16px;
        }

        /* Boarding pass style */
        .ci-boarding-pass {
            background: #0B1B3A;
            border-radius: 12px;
            padding: 18px 20px;
            margin-bottom: 18px;
            text-align: left;
        }

        .bp-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 14px;
        }

        .bp-airline {
            font-family: 'Syne',sans-serif;
            font-size: 13px;
            font-weight: 800;
            color: #fff;
        }

        .bp-type {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: .8px;
            text-transform: uppercase;
            color: rgba(255,255,255,.3);
        }

        .bp-route {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 14px;
        }

        .bp-apt-code {
            font-family: 'Syne',sans-serif;
            font-size: 28px;
            font-weight: 800;
            color: #fff;
            line-height: 1;
        }

        .bp-apt-name {
            font-size: 10px;
            color: rgba(255,255,255,.3);
            margin-top: 2px;
        }

        .bp-route-mid {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            flex: 1;
        }

        .bp-route-line {
            width: 100%;
            height: 1px;
            background: rgba(255,255,255,.15);
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .bp-route-line i {
                font-size: 14px;
                color: #3B8EF5;
                background: #0B1B3A;
                padding: 0 6px;
            }

        .bp-divider {
            border: none;
            border-top: 2px dashed rgba(255,255,255,.1);
            margin: 14px 0;
        }

        .bp-grid {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 12px;
        }

        .bp-item {
        }

        .bp-item-key {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: .8px;
            text-transform: uppercase;
            color: rgba(255,255,255,.3);
        }

        .bp-item-val {
            font-size: 13px;
            font-weight: 600;
            color: rgba(255,255,255,.85);
            margin-top: 2px;
        }

        .bp-barcode {
            background: rgba(255,255,255,.05);
            border-radius: 8px;
            padding: 12px;
            margin-top: 14px;
            text-align: center;
        }

        .bp-barcode-bars {
            display: flex;
            gap: 2px;
            justify-content: center;
            align-items: flex-end;
            height: 36px;
            margin-bottom: 6px;
        }

        .bp-bar {
            background: rgba(255,255,255,.7);
            border-radius: 1px;
        }

        .bp-pnr {
            font-family: monospace;
            font-size: 14px;
            font-weight: 700;
            color: rgba(255,255,255,.5);
            letter-spacing: 2px;
        }

        .modal-btn-row {
            display: flex;
            gap: 10px;
        }

        /* ── Responsive ───────────────────────────────────────── */
        @@media (max-width:1000px) {
            .ci-layout {
                grid-template-columns: 1fr;
            }

            .ci-col-side {
                position: static;
            }

            .ci-banner-meta {
                grid-template-columns: repeat(3,auto);
            }

            .summary-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width:768px) {
            .ci-banner {
                padding: 16px;
            }

            .ci-apt-code {
                font-size: 26px;
            }

            .ci-banner-meta {
                grid-template-columns: 1fr 1fr;
            }

            .tab-step-desc {
                display: none;
            }

            .tab-stepper {
                overflow-x: auto;
            }

            .meal-grid {
                grid-template-columns: 1fr 1fr;
            }

            .extras-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        @@media (max-width:500px) {
            .baggage-cards, .meal-grid, .extras-grid {
                grid-template-columns: 1fr;
            }

            .tab-step-title {
                font-size: 11px;
            }

            .tab-step-num {
                width: 22px;
                height: 22px;
                font-size: 10px;
            }

            .tab-step {
                gap: 6px;
                padding: 12px 8px;
            }
        }

    </style>
}

<main class="main-content" id="main-content">
    <div class="container-fluid px-4 py-4">
        <div class="ci-page">

            @* ── Başlık ── *@
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1" style="font-size:12.5px;">
                            <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">Dashboard</a></li>
                            <li class="breadcrumb-item">
                                <a asp-area="Admin" asp-controller="Bookings" asp-action="BookingList" class="text-decoration-none text-muted">Rezervasyonlar</a>
                            </li>
                            <li class="breadcrumb-item active">Check-In</li>
                        </ol>
                    </nav>
                    <h4 class="fw-bold mb-1" style="color:#0f172a;">Check-In İşlemi</h4>
                    <p class="text-muted mb-0" style="font-size:13px;">Adımları sırasıyla tamamlayın ve check-in'i onaylayın.</p>
                </div>
                <a asp-area="Admin" asp-controller="Bookings" asp-action="BookingList"
                   class="btn btn-outline-secondary btn-sm px-3" style="border-radius:8px;font-size:13px;">
                    <i class="bi bi-arrow-left me-1"></i> Geri
                </a>
            </div>

            @* ── Flight Banner ── *@
            <div class="ci-banner">
                <div class="ci-banner-top">
                    <div class="ci-route">
                        <div style="text-align:center;">
                            <div class="ci-apt-code">@ViewBag.DepartureAirportCode</div>
                            <div class="ci-apt-name">@ViewBag.DepartureAirportName</div>
                        </div>
                        <div class="ci-route-mid">
                            <div class="ci-route-line"><i class="bi bi-airplane-fill"></i></div>
                            <div class="ci-route-dur" id="bannerDur">— dk</div>
                        </div>
                        <div style="text-align:center;">
                            <div class="ci-apt-code">@ViewBag.ArrivalAirportCode</div>
                            <div class="ci-apt-name">@ViewBag.ArrivalAirportName</div>
                        </div>
                    </div>
                    <span class="ci-status-badge">
                        <span class="dot"></span> Planlandı
                    </span>
                </div>
                <hr class="ci-bp-divider" />
                <div class="ci-banner-meta">
                    <div class="ci-meta-item">
                        <span class="ci-meta-key">Uçuş Kodu</span>
                        <span class="ci-meta-val">@ViewBag.FlightNumber</span>
                    </div>
                    <div class="ci-meta-item">
                        <span class="ci-meta-key">Tarih</span>
                        <span class="ci-meta-val">
                            @(ViewBag.DepartureTime != null ? ((DateTime)ViewBag.DepartureTime).ToString("dd MMM yyyy", new System.Globalization.CultureInfo("tr-TR")) : "—")
                        </span>
                    </div>
                    <div class="ci-meta-item">
                        <span class="ci-meta-key">Saat</span>
                        <span class="ci-meta-val">
                            @(ViewBag.DepartureTime != null ? ((DateTime)ViewBag.DepartureTime).ToString("HH:mm") : "—") →
                            @(ViewBag.ArrivalTime != null ? ((DateTime)ViewBag.ArrivalTime).ToString("HH:mm") : "—")
                        </span>
                    </div>
                    <div class="ci-meta-item">
                        <span class="ci-meta-key">Yolcu</span>
                        <span class="ci-meta-val">@ViewBag.Name @ViewBag.Surname</span>
                    </div>
                    <div class="ci-meta-item">
                        <span class="ci-meta-key">PNR</span>
                        <span class="ci-meta-val" style="font-family:monospace;letter-spacing:.8px;">@ViewBag.PnrNumber</span>
                    </div>
                    <div class="ci-meta-item">
                        <span class="ci-meta-key">Kapı</span>
                        <span class="ci-meta-val">@(ViewBag.Gate ?? "—")</span>
                    </div>
                </div>
            </div>

            @* ── Layout ── *@
            <div class="ci-layout">

                @* ── Sol: Sekmeli Form ── *@
                <div class="ci-col-main">

                    @* Step Bar *@
                    <div class="tab-stepper" id="tabStepper">
                        <div class="tab-step active" id="step-tab-1" onclick="goTab(1)">
                            <div class="tab-step-num" id="step-num-1">1</div>
                            <div class="tab-step-text">
                                <div class="tab-step-title">Bagaj</div>
                                <div class="tab-step-desc">Ağırlık seçimi</div>
                            </div>
                        </div>
                        <div class="tab-step" id="step-tab-2" onclick="goTab(2)">
                            <div class="tab-step-num" id="step-num-2">2</div>
                            <div class="tab-step-text">
                                <div class="tab-step-title">Koltuk</div>
                                <div class="tab-step-desc">Koltuk seç</div>
                            </div>
                        </div>
                        <div class="tab-step" id="step-tab-3" onclick="goTab(3)">
                            <div class="tab-step-num" id="step-num-3">3</div>
                            <div class="tab-step-text">
                                <div class="tab-step-title">Yemek</div>
                                <div class="tab-step-desc">Menü seçimi</div>
                            </div>
                        </div>
                        <div class="tab-step" id="step-tab-4" onclick="goTab(4)">
                            <div class="tab-step-num" id="step-num-4">4</div>
                            <div class="tab-step-text">
                                <div class="tab-step-title">Hizmetler</div>
                                <div class="tab-step-desc">Ekstra seç</div>
                            </div>
                        </div>
                        <div class="tab-step" id="step-tab-5" onclick="goTab(5)">
                            <div class="tab-step-num" id="step-num-5">5</div>
                            <div class="tab-step-text">
                                <div class="tab-step-title">Onay</div>
                                <div class="tab-step-desc">Gözden geçir</div>
                            </div>
                        </div>
                    </div>

                    @* Panel Wrapper *@
                    <div class="tab-panels">

                        @* ══════════════════════════════════════════════
                   SEKME 1: BAGAJ
                ══════════════════════════════════════════════ *@
                        <div class="tab-panel active" id="panel-1">
                            <div class="tab-panel-title">Bagaj Seçimi</div>
                            <div class="tab-panel-desc">Yolculuğunuz için uygun bagaj seçeneğini belirleyin.</div>

                            @* Kabin Bagajı *@
                            <div class="baggage-section">
                                <div class="baggage-section-title">
                                    <i class="bi bi-briefcase-fill" style="color:#2563eb;"></i>
                                    Kabin Bagajı
                                    <span style="font-size:11px;color:#94a3b8;font-weight:400;">(uçağa alınabilir)</span>
                                </div>
                                <div class="baggage-cards">
                                    <label class="baggage-card selected" id="cabin-free" onclick="selectBaggage('cabin','free',0)">
                                        <input type="radio" name="cabin_bag" />
                                        <div class="bc-check"><i class="bi bi-check-lg"></i></div>
                                        <div class="bc-icon">🎒</div>
                                        <div class="bc-name">Kişisel Eşya</div>
                                        <div class="bc-sub">Maks. 40×30×15 cm · 6 kg</div>
                                        <div class="bc-price" style="color:#16a34a;">Ücretsiz</div>
                                    </label>
                                    <label class="baggage-card" id="cabin-small" onclick="selectBaggage('cabin','small',80)">
                                        <input type="radio" name="cabin_bag" />
                                        <div class="bc-check"><i class="bi bi-check-lg"></i></div>
                                        <div class="bc-icon">💼</div>
                                        <div class="bc-name">Kabin Valizi (S)</div>
                                        <div class="bc-sub">Maks. 55×40×20 cm · 8 kg</div>
                                        <div class="bc-price">+ 80 @ViewBag.Currency</div>
                                    </label>
                                    <label class="baggage-card" id="cabin-large" onclick="selectBaggage('cabin','large',120)">
                                        <input type="radio" name="cabin_bag" />
                                        <div class="bc-check"><i class="bi bi-check-lg"></i></div>
                                        <div class="bc-icon">🧳</div>
                                        <div class="bc-name">Kabin Valizi (L)</div>
                                        <div class="bc-sub">Maks. 55×40×25 cm · 10 kg</div>
                                        <div class="bc-price">+ 120 @ViewBag.Currency</div>
                                    </label>
                                </div>
                            </div>

                            @* Uçak Altı Bagaj + Slider *@
                            <div class="baggage-section">
                                <div class="baggage-section-title">
                                    <i class="bi bi-archive-fill" style="color:#7c3aed;"></i>
                                    Uçak Altı Bagaj
                                    <span style="font-size:11px;color:#94a3b8;font-weight:400;">(ambar bagajı)</span>
                                </div>

                                <div class="kg-slider-wrap" id="hold-slider-wrap">
                                    <div class="kg-slider-header">
                                        <span class="kg-slider-label">Bagaj Ağırlığı Seçin</span>
                                        <span class="kg-display" id="holdKgDisplay">0 kg</span>
                                    </div>
                                    <input type="range" class="kg-slider" id="holdKgSlider"
                                           min="0" max="32" step="8" value="0"
                                           oninput="updateHoldSlider(this.value)" />
                                    <div class="kg-ticks">
                                        <span class="kg-tick">0 kg<br><span style="color:#16a34a;font-size:9px;">Ücretsiz</span></span>
                                        <span class="kg-tick">8 kg<br><span style="font-size:9px;">100 @ViewBag.Currency</span></span>
                                        <span class="kg-tick">16 kg<br><span style="font-size:9px;">180 @ViewBag.Currency</span></span>
                                        <span class="kg-tick">24 kg<br><span style="font-size:9px;">240 @ViewBag.Currency</span></span>
                                        <span class="kg-tick">32 kg<br><span style="font-size:9px;">300 @ViewBag.Currency</span></span>
                                    </div>
                                </div>

                                <div class="ci-info-note mt-3">
                                    <i class="bi bi-info-circle-fill" style="flex-shrink:0;margin-top:1px;"></i>
                                    <span>Uçak altı bagaj en az 72 saat önceden satın alındığında %20 daha ucuzdur. Check-in'de ek ücret uygulanabilir.</span>
                                </div>
                            </div>

                            @* Özel Bagaj *@
                            <div class="baggage-section">
                                <div class="baggage-section-title">
                                    <i class="bi bi-bicycle" style="color:#d97706;"></i>
                                    Özel & Fazla Bagaj
                                </div>
                                <div class="baggage-cards">
                                    <label class="baggage-card" id="special-sport" onclick="toggleSpecial('sport',150)">
                                        <input type="checkbox" />
                                        <div class="bc-check"><i class="bi bi-check-lg"></i></div>
                                        <div class="bc-icon">🎿</div>
                                        <div class="bc-name">Spor Ekipmanı</div>
                                        <div class="bc-sub">Kayak, sörf, bisiklet vb.</div>
                                        <div class="bc-price">+ 150 @ViewBag.Currency</div>
                                    </label>
                                    <label class="baggage-card" id="special-golf" onclick="toggleSpecial('golf',120)">
                                        <input type="checkbox" />
                                        <div class="bc-check"><i class="bi bi-check-lg"></i></div>
                                        <div class="bc-icon">⛳</div>
                                        <div class="bc-name">Golf Ekipmanı</div>
                                        <div class="bc-sub">Golf çantası + aksesuarlar</div>
                                        <div class="bc-price">+ 120 @ViewBag.Currency</div>
                                    </label>
