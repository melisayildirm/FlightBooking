                </div>
                <div class="bp-item">
                    <div class="bp-item-key">Tarih</div>
                    <div class="bp-item-val">
                        @(ViewBag.DepartureTime != null ? ((DateTime)ViewBag.DepartureTime).ToString("dd MMM", new System.Globalization.CultureInfo("tr-TR")) : "—")
